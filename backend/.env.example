# OIEC backend — environment configuration
# Copy this file to `.env` (same directory) and fill in your credentials.
# NEVER commit `.env` to git. Add `.env` to .gitignore if you haven't already.

# ---------------------------------------------------------------------
# Kalshi credentials — paste the NEW key you generated after the old
# one was rotated out. If you leave these blank the backend runs in
# Polymarket-only mode.
# ---------------------------------------------------------------------

# Key ID (a UUID) from Kalshi settings → API Keys
KALSHI_KEY_ID=

# Absolute or relative path to the private-key PEM file on THIS machine.
# Recommended location: `./kalshi_private_key.pem` (same folder as main.py)
# Make sure this file is readable only by you: `chmod 600 kalshi_private_key.pem`
KALSHI_PEM_PATH=./kalshi_private_key.pem

# "prod" or "demo". Use demo first to confirm signing works with fake money.
KALSHI_ENV=prod

# ---------------------------------------------------------------------
# Backend behavior
# ---------------------------------------------------------------------

# Seconds between API polls (default 3.0). You picked moderate.
OIEC_POLL_INTERVAL=3.0

# Host + port to bind. 127.0.0.1 keeps it local-only (recommended).
OIEC_HOST=127.0.0.1
OIEC_PORT=8000

# Log verbosity: DEBUG, INFO, WARNING, ERROR
OIEC_LOG_LEVEL=INFO
